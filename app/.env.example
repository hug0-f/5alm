# Copier ce fichier en .env (utilise par docker compose) ou .env.local (dev npm).
# Ne jamais committer ces fichiers (ils contiennent les secrets).

# Base de donnees PostgreSQL.
# Elle tourne en conteneur sur le VPS (service "db" du docker-compose).
# POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB sont lus par le conteneur
# postgres ET repris dans DATABASE_URL ci-dessous (memes valeurs).
POSTGRES_USER=lebontroc
POSTGRES_PASSWORD=
POSTGRES_DB=lebontroc

# En Docker compose : l'hote est "db" (nom du service), port 5432 interne.
# En dev local sans Docker : remplacer "db" par "localhost".
DATABASE_URL=postgresql://lebontroc:PASSWORD@db:5432/lebontroc

# Mettre a "true" uniquement pour se connecter a une base managee distante
# qui exige du SSL. Pour la base locale en conteneur, laisser vide.
DATABASE_SSL=

# Authentification NextAuth
# Generer un secret fort : openssl rand -base64 32
NEXTAUTH_SECRET=
AUTH_SECRET=

#NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Service WhatsApp (Baileys) : URL du service interne.
# En Docker compose : http://wa-service:3001 (reseau interne).
# En dev local sans Docker : http://localhost:3001.
WA_SERVICE_URL=http://wa-service:3001

# Origines autorisees par "next dev" (liste separee par virgule).
# Inutile en production (output: standalone n'utilise pas cette option).
ALLOWED_DEV_ORIGINS=
